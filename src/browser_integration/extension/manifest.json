{
  "manifest_version": 3,
  "name": "Virtual FIDO2 Passkey Authenticator",
  "version": "1.0.0",
  "description": "Overrides navigator.credentials.get to use local virtual FIDO2 authenticator.",
  "permissions": [
    "nativeMessaging"
  ],
  "host_permissions": [
    "http://localhost:8000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Virtual FIDO2 Authenticator"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["bridge.js"],
      "run_at": "document_start"
    }
  ]
}
